EXPO_PUBLIC_DORG_PUBLIC_BASE_URL=https://dorg.work
EXPO_PUBLIC_EAS_PROJECT_ID=

# Opptaks-/promodemodus tilbudsflyt (kun når =1). Viser videokamera-ikon i TopBar; ingen effekt i prod uten dette.
# EXPO_PUBLIC_OFFER_FLOW_RECORDING_DEMO=1
# Valgfritt: statisk tilbudstekst uten OpenAI (rask opptak).
# EXPO_PUBLIC_OFFER_FLOW_DEMO_STUB_AI=1
# Valgfritt: simuler sending (ingen Resend/Supabase, ingen toast/kort). Uten denne er sending ekte i demomodus.
# EXPO_PUBLIC_OFFER_FLOW_DEMO_MOCK_SEND=1
