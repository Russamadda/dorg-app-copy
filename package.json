{
  "name": "dorg-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "engines": {
    "node": "^22.0.0 || ^20.19.0"
  },
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "node scripts/patch-chromium-edge-launcher-rimraf.js",
    "graph:flow-1": "npx madge --extensions ts,tsx --exclude \"node_modules|\\.expo\" --image docs/graphs/flow-1-create-offer.svg hooks/useNyttTilbudFlyt.ts components/NyttTilbudModal.tsx",
    "graph:flow-2": "npx madge --extensions ts,tsx --exclude \"node_modules|\\.expo\" --image docs/graphs/flow-2-send-update.svg components/NyttTilbudModal.tsx components/TilbudDetaljerModal.tsx",
    "graph:flow-3": "npx madge --extensions ts,tsx --exclude \"node_modules|\\.expo\" --image docs/graphs/flow-3-justering.svg components/TilbudDetaljerModal.tsx",
    "graph:all": "npm run graph:flow-1 && npm run graph:flow-2 && npm run graph:flow-3"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.2.3",
    "@expo-google-fonts/dm-serif-display": "^0.2.3",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-picker/picker": "2.11.1",
    "@supabase/supabase-js": "^2.45.4",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.7.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-swipe-list-view": "^3.2.9",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "glob": "^13.0.6",
    "rimraf": "^5.0.10",
    "test-exclude": "^8.0.0"
  }
}
